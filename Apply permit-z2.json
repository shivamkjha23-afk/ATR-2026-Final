{
  "title": "Apply permit-z2-search-start",
  "notes": "Starts after user login. Opens IW21 from search, fills required fields, keeps steps minimal and records requisition number manually in ATR UI.",
  "runtime_placeholders": [
    "TITLE",
    "FUNCTIONAL_LOCATION",
    "EQUIPMENT",
    "WORK_CENTER",
    "NO_OF_PERSON",
    "PERMIT_TYPE"
  ],
  "steps": [
    {
      "action": "press",
      "key": "Enter"
    },
    {
      "action": "search_app",
      "selector": {
        "role": "searchbox",
        "text": "Search In: Apps"
      },
      "value": "IW21"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Notification Type Required"
      },
      "value": "Z2"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Short Text"
      },
      "value": "{{TITLE}}"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Functional loc."
      },
      "value": "{{FUNCTIONAL_LOCATION}}"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Equipment"
      },
      "value": "{{EQUIPMENT}}"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Planner Group"
      },
      "value": "INP"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Main WorkCtr"
      },
      "value": "{{WORK_CENTER}}"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Person Involved(Nos) Required"
      },
      "value": "{{NO_OF_PERSON}}"
    },
    {
      "action": "set_field",
      "selector": {
        "text": "Permit Required"
      },
      "value": "Permit require"
    },
    {
      "action": "open_permit_create",
      "selector": {
        "role": "button",
        "text": "Create"
      }
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Work Center Required"
      },
      "value": "{{WORK_CENTER}}"
    },
    {
      "action": "set_field",
      "selector": {
        "aria-label": "Usage"
      },
      "value": "{{PERMIT_TYPE}}"
    },
    {
      "action": "save",
      "selector": {
        "role": "button",
        "text": "Save"
      }
    },
    {
      "action": "capture_requisition_no",
      "source": "status_bar",
      "label": "Record Requisition Number in ATR table"
    },
    {
      "action": "release",
      "selector": {
        "aria-label": "Release"
      }
    },
    {
      "action": "save",
      "selector": {
        "role": "button",
        "text": "Save"
      }
    }
  ]
}
